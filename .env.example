SLACK_BOT_TOKEN=xoxb-xxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxx

# Docker image/runtime UID:GID (set to host user that owns /srv/agent/repos and /srv/agent/worktrees)
PUID=1000
PGID=1000

# Optional settings
# MINI_CMD=mini
# OpenRouter API route (recommended):
# MINI_MODEL_CLASS=openrouter
# MINI_MODEL_NAME=openai/gpt-4.1-mini
# OPENROUTER_API_KEY=sk-or-v1-...
# Optional per-phase model overrides:
# MINI_PLAN_MODEL_CLASS=openrouter
# MINI_PLAN_MODEL_NAME=openai/gpt-4.1-mini
# MINI_IMPLEMENT_MODEL_CLASS=openrouter
# MINI_IMPLEMENT_MODEL_NAME=anthropic/claude-sonnet-4
# MINI_REVIEW_MODEL_CLASS=openrouter
# MINI_REVIEW_MODEL_NAME=openai/o4-mini
# MINI_USE_YOLO=true
# MINI_EXIT_IMMEDIATELY=true
# Skip interactive first-time mini setup (required for Slack/non-TTY runs)
# MSWEA_CONFIGURED=true
# TASK_TIMEOUT_SECONDS=7200
# Post in-thread progress every N seconds while mini is running (0 disables heartbeat)
# PROGRESS_HEARTBEAT_SECONDS=0
# Max chars returned in `status` output tails
# STATUS_OUTPUT_CHARS=1200
# MAX_STDOUT_CHARS=3500
# MAX_STDERR_CHARS=1500
# TASK_PREFIX=swe:
# ALLOW_CHANNEL_IDS=C0123456789,C0987654321
# REPO_CONFIG_PATH=/opt/mini-swe-slack/repos.json
# WORKTREE_ROOT=/opt/mini-swe-slack/.worktrees
# GIT_FETCH_BEFORE_WORKTREE=true
# KEEP_WORKTREE_ON_FAILURE=false
# WORKFLOW_GUIDE_PATH=/app/prompts/workflow.md
# PLAN_GUIDE_PATH=/app/prompts/planning.md
# REVIEW_GUIDE_PATH=/app/prompts/review.md
# PLAN_OUTPUT_FILENAME=.mini_workflow_plan.json
# REVIEW_OUTPUT_FILENAME=.mini_workflow_review.json
# MAX_IMPLEMENT_REVIEW_LOOPS=3
# WEB_UI_ENABLED=true
# WEB_UI_BIND=0.0.0.0
# WEB_UI_PORT=8787
# WEB_UI_MAX_SESSIONS=200
# Container-friendly defaults:
# REPO_CONFIG_PATH=/app/repos.json
# WORKTREE_ROOT=/worktrees
